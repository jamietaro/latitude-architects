generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id               Int                    @id @default(autoincrement())
  title            String
  slug             String                 @unique
  location         String
  client           String?
  year             Int
  status           String
  sectors          String
  shortDescription String?
  description      String
  featured         Boolean                @default(false)
  published        Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  images           ProjectImage[]
  categoryOrders   ProjectCategoryOrder[]
  heroSlides       HeroSlide[]
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

model ProjectCategoryOrder {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category  String
  order     Int     @default(0)

  @@unique([projectId, category])
  @@index([category])
}

model NewsPost {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  date      DateTime
  category  String
  body      String
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  title     String
  bio       String
  photo     String?
  order     Int      @default(0)
  published Boolean  @default(false)
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id             Int         @id @default(1)
  heroTagline    String?     @default("Celebrating 25 years of crafting exceptional buildings across London and beyond.")
  bannerImageUrl String?
  bannerTagline  String?     @default("Buildings for people.")
  bannerCta      String?     @default("Get in touch")
  updatedAt      DateTime    @updatedAt
  heroSlides     HeroSlide[]
}

model AboutBlock {
  id       Int     @id
  imageUrl String?
  tagline  String?
  body     String?
}

model TeamPageContent {
  id      Int     @id @default(1)
  heading String?
  intro   String?
}

model ClientsPageContent {
  id      Int     @id @default(1)
  heading String?
  intro   String?
  body    String?
}

model CareersPageContent {
  id        Int     @id @default(1)
  heading   String?
  intro     String?
  vacancies String?
}

model ContactPageContent {
  id       Int     @id @default(1)
  heading  String?
  address  String?
  phone    String?
  email    String?
  body     String?
  imageUrl String?
}

model HeroSlide {
  id             Int          @id @default(autoincrement())
  siteSettingsId Int
  settings       SiteSettings @relation(fields: [siteSettingsId], references: [id], onDelete: Cascade)
  projectId      Int?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  imageUrl       String
  opacity        Float        @default(0.85)
  order          Int          @default(0)
}
