generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id               Int            @id @default(autoincrement())
  title            String
  slug             String         @unique
  location         String
  client           String?
  year             Int
  status           String
  sectors          String
  shortDescription String?
  description      String
  featured         Boolean        @default(false)
  published        Boolean        @default(false)
  order            Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProjectImage[]
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

model NewsPost {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  date      DateTime
  category  String
  body      String
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  title     String
  bio       String
  photo     String?
  order     Int      @default(0)
  published Boolean  @default(false)
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
